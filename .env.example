# Copy this file to .env and fill in your own values. Never commit .env.

# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Telegram bot for the Chief Execution Officer's alerts (Phase 5)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Used for AI-generated agent summaries (Phase 2+)
ANTHROPIC_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with real contact info, e.g.
# "AI CFO Platform yourname@example.com" — see connectors/sec_edgar_connector.py
SEC_USER_AGENT=

# Public market-news RSS feed for the Chief Sentiment Officer. Leave blank
# to use the default (MarketWatch top stories, free, no key).
NEWS_RSS_URL=

# Minimum quality score (0-100) required before any dataset is considered usable
MIN_DATA_QUALITY=60

LOG_LEVEL=INFO
